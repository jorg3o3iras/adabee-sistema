# ============================================
# CONFIGURAÇÃO GEMINI (LENDO DO .env)
# ============================================
GEMINI_AVAILABLE = False
model = None
GEMINI_MODEL = None

try:
    import google.generativeai as genai
    
    # Lê a chave do .env (NÃO está mais no código!)
    GEMINI_API_KEY = os.getenv('GEMINI_API_KEY')
    
    if GEMINI_API_KEY:
        genai.configure(api_key=GEMINI_API_KEY)
        GEMINI_MODEL = os.getenv('GEMINI_MODEL', 'gemini-1.5-flash')
        model = genai.GenerativeModel(GEMINI_MODEL)
        GEMINI_AVAILABLE = True
        print("✅ Gemini AI configurado com sucesso!")
        print(f"📌 Modelo: {GEMINI_MODEL}")
    else:
        print("⚠️ GEMINI_API_KEY não encontrada no .env")
        print("   Usando simulação como fallback")
        
except ImportError:
    print("⚠️ Gemini AI não instalado")
except Exception as e:
    print(f"⚠️ Erro ao configurar Gemini: {e}")
